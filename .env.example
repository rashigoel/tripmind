# ── LLM Backend ──────────────────────────────────────────────────────────────
# Choose: external (LLM gateway) or ollama (local)
LLM_PROVIDER=external
EXTERNAL_BASE_URL=http://0.0.0.0:8100
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── MCP Tool API Keys ─────────────────────────────────────────────────────────
# OpenTripMap — https://dev.opentripmap.org  (free, 5k req/day)
OPENTRIPMAP_API_KEY=your_opentripmap_key_here

# Foursquare Places v3 — https://foursquare.com/developers  (free, 10k/month)
FOURSQUARE_API_KEY=your_foursquare_api_key_here


# ── Server ────────────────────────────────────────────────────────────────────
TRIPMIND_PORT=8200
